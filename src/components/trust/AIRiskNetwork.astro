---
/**
 * AIRiskNetwork — Central brain with 6 radial threat nodes + containment boundary
 * Replaces S6 AI Risk DiagramPlaceholder
 */
const threats = [
  { label: 'Prompt Injection', angle: 0 },
  { label: 'Data Leakage', angle: 60 },
  { label: 'Hallucination', angle: 120 },
  { label: 'Unauthorized Access', angle: 180 },
  { label: 'Output Bias', angle: 240 },
  { label: 'Model Drift', angle: 300 },
];

const cx = 250;
const cy = 180;
const threatRadius = 120;
const nodeRadius = 22;

// Pre-compute threat node positions
const threatNodes = threats.map((t, i) => {
  const rads = (t.angle * Math.PI) / 180;
  return {
    x: cx + threatRadius * Math.cos(rads),
    y: cy + threatRadius * Math.sin(rads),
    label: t.label,
    delay: i * 150,
  };
});
---

<div class="max-w-3xl mx-auto">
  {/* Desktop SVG */}
  <svg
    viewBox="0 0 500 360"
    class="hidden md:block w-full h-auto"
    role="img"
    aria-label="AI risk network showing 6 threat vectors around a central brain node with containment boundary"
  >
    {/* Containment boundary circle (dashed emerald) */}
    <circle
      cx={cx} cy={cy} r={threatRadius + 30}
      fill="none"
      stroke="rgb(var(--color-signal-emerald) / 0.2)"
      stroke-width="1.5"
      stroke-dasharray="8 6"
      class="containment-ring"
    />
    <text
      x={cx} y={cy - threatRadius - 40}
      text-anchor="middle"
      fill="rgb(var(--color-signal-emerald) / 0.6)"
      font-size="9"
      font-weight="600"
      letter-spacing="0.1em"
    >
      CONTAINMENT BOUNDARY
    </text>

    {/* Connections from center to threat nodes */}
    {threatNodes.map((node) => (
      <line
        x1={cx} y1={cy} x2={node.x} y2={node.y}
        stroke="rgb(var(--color-signal-amber) / 0.15)"
        stroke-width="1"
        stroke-dasharray="4 4"
      />
    ))}

    {/* Central brain node */}
    <g class="brain-center">
      <circle
        cx={cx} cy={cy} r="32"
        fill="rgb(var(--color-signal-blue) / 0.08)"
        stroke="rgb(var(--color-signal-blue) / 0.3)"
        stroke-width="1.5"
      />
      <path
        d={`M${cx} ${cy - 12} a7 7 0 0 1 6 3.5 5.5 5.5 0 0 1 2 9 7 7 0 0 1-8 8 7 7 0 0 1-8-8 5.5 5.5 0 0 1 2-9 7 7 0 0 1 6-3.5z`}
        fill="none"
        stroke="rgb(var(--color-signal-blue))"
        stroke-width="1.2"
        stroke-linecap="round"
      />
      <line
        x1={cx} y1={cy - 10} x2={cx} y2={cy + 10}
        stroke="rgb(var(--color-signal-blue) / 0.4)"
        stroke-width="1"
      />
    </g>

    {/* Threat nodes */}
    {threatNodes.map((node) => (
      <g class="threat-node" style={`animation-delay: ${node.delay}ms;`}>
        <circle
          cx={node.x} cy={node.y} r={nodeRadius}
          fill="rgb(var(--color-signal-amber) / 0.1)"
          stroke="rgb(var(--color-signal-amber) / 0.35)"
          stroke-width="1.5"
        />
        <text
          x={node.x} y={node.y + nodeRadius + 14}
          text-anchor="middle"
          fill="rgb(var(--color-content-secondary))"
          font-size="9"
          font-weight="500"
        >
          {node.label}
        </text>
        <text
          x={node.x} y={node.y + 4}
          text-anchor="middle"
          dominant-baseline="central"
          fill="rgb(var(--color-signal-amber))"
          font-size="14"
        >
          !
        </text>
      </g>
    ))}
  </svg>

  {/* Mobile fallback */}
  <div class="md:hidden space-y-3">
    <div class="flex items-center justify-center gap-3 p-4 rounded-lg bg-signal-blue/10 border border-signal-blue/20">
      <div class="w-8 h-8 rounded-full bg-signal-blue/20 flex items-center justify-center text-signal-blue text-label-md font-semibold shrink-0">
        AI
      </div>
      <span class="text-body-sm font-semibold text-content">AI System (Controlled)</span>
    </div>
    <div class="grid grid-cols-2 gap-2">
      {threats.map((threat) => (
        <div class="flex items-center gap-2 p-3 rounded-lg bg-signal-amber/10 border border-signal-amber/20">
          <span class="text-signal-amber text-label-md font-bold">!</span>
          <span class="text-body-xs text-content-secondary">{threat.label}</span>
        </div>
      ))}
    </div>
    <div class="text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-signal-emerald/10 border border-signal-emerald/20 text-label-sm text-signal-emerald">
        Containment Boundary Active
      </span>
    </div>
  </div>
</div>

<style>
  .containment-ring {
    animation: glow-breathe 8s ease-in-out infinite;
  }
  .brain-center circle {
    animation: node-pulse 4s ease-in-out infinite;
  }
  .threat-node {
    opacity: 0;
    animation: threat-appear 0.5s ease-out forwards;
  }
  @keyframes threat-appear {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .containment-ring,
    .brain-center circle,
    .threat-node {
      animation: none;
      opacity: 1;
    }
  }
</style>
