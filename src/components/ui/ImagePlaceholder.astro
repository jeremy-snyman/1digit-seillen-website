---
import Icon from './Icon.astro';

interface Props {
  aspect?: '16/9' | '4/3' | '1/1';
  label: string;
  class?: string;
  variant?: 'default' | 'premium';
  icon?: string;
  accentColor?: 'blue' | 'purple' | 'emerald' | 'amber';
}

const {
  aspect = '16/9',
  label,
  class: className,
  variant = 'default',
  icon,
  accentColor = 'blue',
} = Astro.props;

const accentMap = {
  blue: {
    mesh1: 'bg-signal-blue/15',
    mesh2: 'bg-signal-purple/10',
    iconBg: 'bg-signal-blue/15 border-signal-blue/25',
    iconColor: 'text-signal-blue',
    glow: 'bg-signal-blue/10',
  },
  purple: {
    mesh1: 'bg-signal-purple/15',
    mesh2: 'bg-signal-blue/10',
    iconBg: 'bg-signal-purple/15 border-signal-purple/25',
    iconColor: 'text-signal-purple',
    glow: 'bg-signal-purple/10',
  },
  emerald: {
    mesh1: 'bg-signal-emerald/15',
    mesh2: 'bg-signal-blue/10',
    iconBg: 'bg-signal-emerald/15 border-signal-emerald/25',
    iconColor: 'text-signal-emerald',
    glow: 'bg-signal-emerald/10',
  },
  amber: {
    mesh1: 'bg-signal-amber/15',
    mesh2: 'bg-signal-purple/10',
    iconBg: 'bg-signal-amber/15 border-signal-amber/25',
    iconColor: 'text-signal-amber',
    glow: 'bg-signal-amber/10',
  },
};

const colors = accentMap[accentColor];
---

{variant === 'default' ? (
  <div
    class:list={[
      'glass-card flex items-center justify-center border-dashed border-tint/10',
      className,
    ]}
    style={`aspect-ratio: ${aspect};`}
  >
    <div class="text-center px-4">
      <svg class="w-8 h-8 mx-auto mb-2 text-content-meta/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
      </svg>
      <p class="text-body-xs text-content-meta">{label}</p>
    </div>
  </div>
) : (
  <div
    class:list={['glass-card-premium overflow-hidden relative', className]}
    style={`aspect-ratio: ${aspect};`}
  >
    {/* Animated mesh gradient background */}
    <div class:list={['mesh-gradient w-[70%] h-[70%] top-[-10%] left-[-10%]', colors.mesh1]} style="animation: drift 12s ease-in-out infinite;"></div>
    <div class:list={['mesh-gradient w-[60%] h-[60%] bottom-[-5%] right-[-10%]', colors.mesh2]} style="animation: mesh-drift-2 14s ease-in-out infinite;"></div>

    {/* Radial vignette edge mask */}
    <div class="absolute inset-0 z-[1]" style="background: radial-gradient(ellipse at center, transparent 40%, rgb(var(--glass-bg)) 90%);"></div>

    {/* Centered icon */}
    <div class="absolute inset-0 z-[2] flex flex-col items-center justify-center">
      <div class:list={['w-16 h-16 rounded-2xl border flex items-center justify-center mb-4', colors.iconBg]} style="animation: glow-breathe 4s ease-in-out infinite;">
        {icon && <Icon name={icon} size={32} class={colors.iconColor} />}
      </div>
      <p class="text-heading-xs font-semibold text-content">{label}</p>
      <p class="text-body-sm text-content-muted mt-1">AI-generated visual coming soon</p>
    </div>

    {/* Glow backdrop */}
    <div class:list={['absolute w-32 h-32 rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 blur-3xl z-0', colors.glow]} style="animation: glow-breathe 6s ease-in-out infinite;"></div>
  </div>
)}
