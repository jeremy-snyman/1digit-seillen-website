---
interface Props {
  aspect?: '16/9' | '4/3' | '1/1';
  label: string;
  class?: string;
}

const { aspect = '16/9', label, class: className } = Astro.props;
---

<div
  class:list={[
    'glass-card flex items-center justify-center border-dashed border-tint/10',
    className,
  ]}
  style={`aspect-ratio: ${aspect};`}
>
  <div class="text-center px-4">
    <svg class="w-8 h-8 mx-auto mb-2 text-content-meta/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
    </svg>
    <p class="text-body-xs text-content-meta">{label}</p>
  </div>
</div>
