---
import GlassCard from '@components/ui/GlassCard.astro';
import Icon from '@components/ui/Icon.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  color?: 'blue' | 'purple' | 'amber' | 'emerald';
}

const { icon, title, description, href, color } = Astro.props;

const colorMap = {
  blue: { bg: 'bg-signal-blue/15 border border-signal-blue/20', text: 'text-signal-blue' },
  purple: { bg: 'bg-signal-purple/15 border border-signal-purple/20', text: 'text-signal-purple' },
  amber: { bg: 'bg-signal-amber/15 border border-signal-amber/20', text: 'text-signal-amber' },
  emerald: { bg: 'bg-signal-emerald/15 border border-signal-emerald/20', text: 'text-signal-emerald' },
};

const colorClasses = color ? colorMap[color] : { bg: 'bg-surface-subtle', text: 'text-glow-blue' };
---

<a href={href} class="group block">
  <GlassCard hover padding="md" class="h-full">
    <div class="flex flex-col gap-4">
      <div class:list={[
        'w-12 h-12 rounded-card-sm flex items-center justify-center',
        colorClasses.bg, colorClasses.text,
      ]}>
        <Icon name={icon} size={24} />
      </div>
      <h3 class="text-heading-sm">{title}</h3>
      <p class="text-body-sm text-content-secondary">{description}</p>
      <div class="flex items-center gap-1 text-content-secondary text-body-sm font-medium mt-auto pt-2 group-hover:gap-2 transition-all">
        Learn more <Icon name="arrow-right" size={16} />
      </div>
    </div>
  </GlassCard>
</a>
