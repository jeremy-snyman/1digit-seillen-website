---
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import Icon from '@components/ui/Icon.astro';
import ScrollReveal from '@components/interactive/ScrollReveal.astro';

const signals = [
  { icon: 'shield', label: 'Secure SDLC' },
  { icon: 'lock', label: 'Governance Frameworks' },
  { icon: 'check', label: 'ISO 27001 Awareness' },
  { icon: 'globe', label: 'GDPR Compliant' },
  { icon: 'chart', label: 'Risk Modelling' },
];
---

<Section padding="sm">
  <Container>
    {/* Top divider */}
    <div class="section-divider mb-10"></div>

    <p class="text-center text-label-md uppercase tracking-wider text-content-meta mb-6">Enterprise Standards</p>

    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-6">
      {signals.map((signal, i) => (
        <ScrollReveal delay={i * 80}>
          <div class="flex items-center gap-3">
            {/* Vertical separator (desktop, not before first) */}
            {i > 0 && (
              <div class="hidden md:block w-px h-8 bg-tint/[0.06] -ml-3 mr-3"></div>
            )}
            <div class="w-11 h-11 rounded-xl bg-tint/[0.04] border border-tint/[0.06] flex items-center justify-center">
              <Icon name={signal.icon} size={18} class="text-accent/70" />
            </div>
            <span class="text-body-sm font-medium text-content-muted">{signal.label}</span>
          </div>
        </ScrollReveal>
      ))}
    </div>

    {/* Bottom divider */}
    <div class="section-divider mt-10"></div>
  </Container>
</Section>
