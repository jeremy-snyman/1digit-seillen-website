---
import GlassCard from '@components/ui/GlassCard.astro';
import Icon from '@components/ui/Icon.astro';
import Button from '@components/ui/Button.astro';
import FeatureList from './FeatureList.astro';
import ExpandableDetail from './ExpandableDetail.astro';
import ImagePlaceholder from '@components/ui/ImagePlaceholder.astro';

interface Props {
  number: string;
  title: string;
  icon: string;
  problem: string;
  approach: string[];
  deliverables: string[];
  outcomes: string[];
  timeframe: string;
  cta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  index?: number;
  image?: string;
  thumbnail?: string;
  thumbnailLight?: string;
  accentColor?: 'blue' | 'amber' | 'purple' | 'emerald';
}

const { title, icon, problem, approach, deliverables, outcomes, cta, secondaryCta, index = 0, thumbnail, thumbnailLight, accentColor } = Astro.props;
const isOdd = index % 2 !== 0;

const borderColorMap: Record<string, string> = {
  blue: 'border-l-signal-blue/40',
  amber: 'border-l-signal-amber/40',
  purple: 'border-l-signal-purple/40',
  emerald: 'border-l-signal-emerald/40',
};

const textColorMap: Record<string, string> = {
  blue: 'text-signal-blue',
  amber: 'text-signal-amber',
  purple: 'text-signal-purple',
  emerald: 'text-signal-emerald',
};

const badgeBgMap: Record<string, string> = {
  blue: 'bg-signal-blue/20 text-signal-blue',
  amber: 'bg-signal-amber/20 text-signal-amber',
  purple: 'bg-signal-purple/20 text-signal-purple',
  emerald: 'bg-signal-emerald/20 text-signal-emerald',
};

const borderClass = accentColor ? borderColorMap[accentColor] : '';
const iconColor = accentColor ? textColorMap[accentColor] : 'text-glow-blue';
const badgeColor = accentColor ? badgeBgMap[accentColor] : 'bg-glow-steel/20 text-glow-blue';
---

<GlassCard padding="lg" class={`relative overflow-hidden border-l-2 ${borderClass} shadow-lg shadow-black/10 border border-tint/[0.08]`}>

  <div class="relative grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
    <!-- Column 1: Info -->
    <div class={isOdd ? 'md:order-last' : ''}>
      <div class="flex items-center gap-4 mb-6">
        <div class="w-12 h-12 rounded-xl bg-surface-subtle flex items-center justify-center">
          <Icon name={icon} size={24} class={iconColor} />
        </div>
        <div>
          <h3 class="text-heading-md font-semibold">{title}</h3>
        </div>
      </div>

      <p class="text-body-lg text-content-secondary mb-6">{problem}</p>

      {index === 0 && (
        <div class="glass-card p-4 mb-6 border border-glow-steel/20">
          <p class="text-body-sm text-content-secondary mb-3">
            Not sure where you stand? Take our 10-minute AI Readiness Assessment.
          </p>
          <Button variant="outline" size="sm" href="/ai-readiness-assessment">
            Assess Your Readiness
          </Button>
        </div>
      )}

      <div class="mb-6">
        <h4 class="text-label-md uppercase tracking-wider text-content-muted mb-3">Typical Outcomes</h4>
        <div class="flex flex-wrap gap-2">
          {outcomes.map((outcome) => (
            <span class={`px-3 py-1 rounded-badge text-body-sm ${badgeColor}`}>{outcome}</span>
          ))}
        </div>
      </div>

      <div class="flex items-center justify-end border-t border-surface-border pt-6">
        <div class="flex gap-3">
          {secondaryCta && (
            <Button variant="outline" size="sm" href={secondaryCta.href}>{secondaryCta.label}</Button>
          )}
          <Button variant="primary" size="sm" href={cta.href}>{cta.label}</Button>
        </div>
      </div>
    </div>

    <!-- Column 2: Expandable Details -->
    <div>
      {thumbnail ? (
        <>
          <img src={thumbnail} alt=""
               class="w-full h-auto mb-6 pillar-thumb-dark"
               loading="lazy" />
          <img src={thumbnailLight || thumbnail} alt=""
               class="w-full h-auto mb-6 pillar-thumb-light"
               loading="lazy" />
        </>
      ) : (
        <div class="mb-6">
          <ImagePlaceholder aspect="4/3" label={title} />
        </div>
      )}
      <ExpandableDetail title="Our Approach">
        <ul class="space-y-2">
          {approach.map((item) => (
            <li class="flex items-start gap-3 text-body-md text-content-secondary">
              <Icon name="chevron-right" size={16} class={`${iconColor} mt-1 shrink-0`} />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </ExpandableDetail>

      <ExpandableDetail title="What You Get">
        <FeatureList items={deliverables} />
      </ExpandableDetail>
    </div>
  </div>
</GlassCard>
