---
interface Props {
  name: string;
  description: string;
  priceRange: string;
  duration: string;
  highlighted?: boolean;
  accentColor?: string;
  class?: string;
}

const { name, description, priceRange, duration, highlighted = false, accentColor, class: className } = Astro.props;
---

<div
  class:list={[
    'grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 items-center px-5 py-5 md:py-4 transition-colors duration-200 rounded-lg',
    highlighted ? 'bg-tint/5' : 'hover:bg-tint/5',
    className,
  ]}
>
  {/* Name + description */}
  <div class="md:col-span-5">
    <div class="flex items-center gap-2.5">
      {accentColor && (
        <div
          class="w-2.5 h-2.5 rounded-full shrink-0"
          style={`background: ${accentColor}; box-shadow: 0 0 8px ${accentColor}44;`}
        ></div>
      )}
      <h3 class="text-body-md font-semibold">{name}</h3>
      {highlighted && (
        <span class="text-label-sm px-2 py-0.5 rounded-full bg-signal-purple/15 text-content-secondary border border-signal-purple/30">
          Popular
        </span>
      )}
    </div>
    <p class="text-body-sm text-content-muted mt-1">{description}</p>
  </div>

  {/* Duration */}
  <div class="md:col-span-3">
    <span class="text-label-sm text-content-muted uppercase tracking-wider md:hidden">Duration: </span>
    <span class="text-body-sm text-content-secondary">{duration}</span>
  </div>

  {/* Price */}
  <div class="md:col-span-4 md:text-right">
    <span class="text-label-sm text-content-muted uppercase tracking-wider md:hidden">Investment: </span>
    <span class="text-heading-sm text-accent-bright font-semibold">{priceRange}</span>
  </div>
</div>
