---
/**
 * ArchitectureStack — Theme-aware SVG stack diagram for the Tachyon Intelligence Platform.
 * Shows all 4 tiers with named technology components and data flow connectors.
 * Uses CSS variables for automatic dark/light theme adaptation.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['architecture-stack w-full', className]}>
  <svg
    viewBox="0 0 800 480"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-auto"
    role="img"
    aria-label="Tachyon Intelligence Platform architecture diagram showing four tiers: Analytics and AI, Processing and Query, Unified Data Lake, and IONOS Cloud Infrastructure"
  >
    <defs>
      {/* Arrow marker */}
      <marker id="arrow-down" viewBox="0 0 10 10" refX="5" refY="10" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M0 0 L5 10 L10 0" class="arch-arrow" />
      </marker>

      {/* Glow filters */}
      <filter id="glow-purple" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
      <filter id="glow-blue" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
    </defs>

    {/* ── Tier 1: Analytics & AI (Purple) ── */}
    <g class="arch-tier-purple">
      {/* Tier background */}
      <rect x="60" y="20" width="680" height="90" rx="12" class="arch-tier-bg-purple" />
      {/* Tier label */}
      <text x="80" y="48" class="arch-tier-label-purple">Analytics & AI</text>

      {/* Component pills */}
      <rect x="80" y="58" width="130" height="36" rx="8" class="arch-pill-purple" />
      <text x="145" y="81" class="arch-pill-text">Superset</text>

      <rect x="226" y="58" width="150" height="36" rx="8" class="arch-pill-purple" />
      <text x="301" y="81" class="arch-pill-text">AI/ML Pipelines</text>

      <rect x="392" y="58" width="160" height="36" rx="8" class="arch-pill-purple" />
      <text x="472" y="81" class="arch-pill-text">Data Catalogue</text>

      <rect x="568" y="58" width="152" height="36" rx="8" class="arch-pill-purple" />
      <text x="644" y="81" class="arch-pill-text">Governance</text>
    </g>

    {/* Connector: Tier 1 → Tier 2 */}
    <g class="arch-connectors">
      <line x1="300" y1="110" x2="300" y2="140" class="arch-connector-line" marker-end="url(#arrow-down)" />
      <line x1="500" y1="110" x2="500" y2="140" class="arch-connector-line" marker-end="url(#arrow-down)" />
    </g>

    {/* ── Tier 2: Processing & Query (Blue) ── */}
    <g class="arch-tier-blue">
      <rect x="60" y="140" width="680" height="90" rx="12" class="arch-tier-bg-blue" />
      <text x="80" y="168" class="arch-tier-label-blue">Processing & Query</text>

      <rect x="80" y="178" width="200" height="36" rx="8" class="arch-pill-blue" />
      <text x="180" y="201" class="arch-pill-text">Trino (Distributed SQL)</text>

      <rect x="296" y="178" width="190" height="36" rx="8" class="arch-pill-blue" />
      <text x="391" y="201" class="arch-pill-text">Kafka (Streaming)</text>

      <rect x="502" y="178" width="218" height="36" rx="8" class="arch-pill-blue" />
      <text x="611" y="201" class="arch-pill-text">Intelligent Caching</text>
    </g>

    {/* Connector: Tier 2 → Tier 3 */}
    <g class="arch-connectors">
      <line x1="300" y1="230" x2="300" y2="260" class="arch-connector-line" marker-end="url(#arrow-down)" />
      <line x1="500" y1="230" x2="500" y2="260" class="arch-connector-line" marker-end="url(#arrow-down)" />
    </g>

    {/* ── Tier 3: Unified Data Lake (Emerald) ── */}
    <g class="arch-tier-emerald">
      <rect x="60" y="260" width="680" height="90" rx="12" class="arch-tier-bg-emerald" />
      <text x="80" y="288" class="arch-tier-label-emerald">Unified Data Lake</text>

      <rect x="80" y="298" width="180" height="36" rx="8" class="arch-pill-emerald" />
      <text x="170" y="321" class="arch-pill-text">Apache Iceberg</text>

      <rect x="276" y="298" width="200" height="36" rx="8" class="arch-pill-emerald" />
      <text x="376" y="321" class="arch-pill-text">Open Table Formats</text>

      <rect x="492" y="298" width="228" height="36" rx="8" class="arch-pill-emerald" />
      <text x="606" y="321" class="arch-pill-text">S3-Compatible Storage</text>
    </g>

    {/* Connector: Tier 3 → Tier 4 */}
    <g class="arch-connectors">
      <line x1="300" y1="350" x2="300" y2="380" class="arch-connector-line" marker-end="url(#arrow-down)" />
      <line x1="500" y1="350" x2="500" y2="380" class="arch-connector-line" marker-end="url(#arrow-down)" />
    </g>

    {/* ── Tier 4: IONOS Cloud Infrastructure (Amber) ── */}
    <g class="arch-tier-amber">
      <rect x="60" y="380" width="680" height="90" rx="12" class="arch-tier-bg-amber" />
      <text x="80" y="408" class="arch-tier-label-amber">IONOS Cloud Infrastructure</text>

      <rect x="80" y="418" width="140" height="36" rx="8" class="arch-pill-amber" />
      <text x="150" y="441" class="arch-pill-text">Kubernetes</text>

      <rect x="236" y="418" width="120" height="36" rx="8" class="arch-pill-amber" />
      <text x="296" y="441" class="arch-pill-text">Compute</text>

      <rect x="372" y="418" width="120" height="36" rx="8" class="arch-pill-amber" />
      <text x="432" y="441" class="arch-pill-text">Network</text>

      <rect x="508" y="418" width="212" height="36" rx="8" class="arch-pill-amber" />
      <text x="614" y="441" class="arch-pill-text">EU Data Centres</text>
    </g>

    {/* Side label: Data flow direction */}
    <text x="32" y="250" class="arch-side-label" transform="rotate(-90 32 250)">Data Flow</text>
  </svg>
</div>

<style>
  /* Tier backgrounds */
  .arch-tier-bg-purple {
    fill: rgb(var(--color-signal-purple) / 0.08);
    stroke: rgb(var(--color-signal-purple) / 0.25);
    stroke-width: 1;
  }
  .arch-tier-bg-blue {
    fill: rgb(var(--color-signal-blue) / 0.08);
    stroke: rgb(var(--color-signal-blue) / 0.25);
    stroke-width: 1;
  }
  .arch-tier-bg-emerald {
    fill: rgb(var(--color-signal-emerald) / 0.08);
    stroke: rgb(var(--color-signal-emerald) / 0.25);
    stroke-width: 1;
  }
  .arch-tier-bg-amber {
    fill: rgb(var(--color-signal-amber) / 0.08);
    stroke: rgb(var(--color-signal-amber) / 0.25);
    stroke-width: 1;
  }

  /* Tier labels */
  .arch-tier-label-purple {
    fill: rgb(var(--color-signal-purple));
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-sans, 'Inter', sans-serif);
    letter-spacing: 0.02em;
  }
  .arch-tier-label-blue {
    fill: rgb(var(--color-signal-blue));
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-sans, 'Inter', sans-serif);
    letter-spacing: 0.02em;
  }
  .arch-tier-label-emerald {
    fill: rgb(var(--color-signal-emerald));
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-sans, 'Inter', sans-serif);
    letter-spacing: 0.02em;
  }
  .arch-tier-label-amber {
    fill: rgb(var(--color-signal-amber));
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-sans, 'Inter', sans-serif);
    letter-spacing: 0.02em;
  }

  /* Component pills */
  .arch-pill-purple {
    fill: rgb(var(--color-signal-purple) / 0.15);
    stroke: rgb(var(--color-signal-purple) / 0.30);
    stroke-width: 1;
  }
  .arch-pill-blue {
    fill: rgb(var(--color-signal-blue) / 0.15);
    stroke: rgb(var(--color-signal-blue) / 0.30);
    stroke-width: 1;
  }
  .arch-pill-emerald {
    fill: rgb(var(--color-signal-emerald) / 0.15);
    stroke: rgb(var(--color-signal-emerald) / 0.30);
    stroke-width: 1;
  }
  .arch-pill-amber {
    fill: rgb(var(--color-signal-amber) / 0.15);
    stroke: rgb(var(--color-signal-amber) / 0.30);
    stroke-width: 1;
  }

  /* Pill text */
  .arch-pill-text {
    fill: rgb(var(--color-content));
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font-sans, 'Inter', sans-serif);
    text-anchor: middle;
    dominant-baseline: central;
  }

  /* Connectors */
  .arch-connector-line {
    stroke: rgb(var(--color-content-muted) / 0.3);
    stroke-width: 1.5;
    stroke-dasharray: 4 3;
  }
  .arch-arrow {
    fill: rgb(var(--color-content-muted) / 0.3);
  }

  /* Side label */
  .arch-side-label {
    fill: rgb(var(--color-content-muted) / 0.4);
    font-size: 11px;
    font-weight: 500;
    font-family: var(--font-sans, 'Inter', sans-serif);
    text-anchor: middle;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
