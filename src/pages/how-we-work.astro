---
import PageLayout from '@layouts/PageLayout.astro';
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import ScrollReveal from '@components/interactive/ScrollReveal.astro';
import GlassCard from '@components/ui/GlassCard.astro';
import Icon from '@components/ui/Icon.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import FeatureList from '@components/content/FeatureList.astro';
import PhaseRail from '@components/content/PhaseRail.astro';
import PhaseCard from '@components/content/PhaseCard.astro';
import MilestoneGates from '@components/content/MilestoneGates.astro';
import {
  processSteps,
  commercialCheckpoints,
  partnershipInputs,
  definitionOfDone,
} from '@content/data/services';

const title = 'How We Work';
const description = 'Four phases. Clear gates. No chaos.';

const phaseRailItems = processSteps.map((s) => ({ number: s.number, title: s.title }));
const milestoneGates = processSteps.map((s) => s.gate);
const phaseNames = processSteps.map((s) => s.title);

const phaseColors = ['#64C8FF', '#A064FF', '#50DCB4', '#FFB43C'];

const checkpointColors = ['#64C8FF', '#A064FF', '#50DCB4', '#FFB43C'];

const dodColors = ['#64C8FF', '#A064FF', '#50DCB4', '#FFB43C'];
const dodIcons = ['clipboard', 'check', 'users', 'arrow-right'];
---

<PageLayout title={title} description={description}>

  {/* ── Section 1: Hero ── */}
  <Section class="pt-40 pb-24 relative overflow-hidden min-h-[70vh]">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
      <div class="w-[600px] h-[300px] bg-signal-blue/15 rounded-full blur-[120px]" style="animation: drift 20s ease-in-out infinite;"></div>
      <div class="w-[400px] h-[250px] bg-signal-purple/10 rounded-full blur-[100px] absolute top-1/3 left-1/3" style="animation: mesh-drift-1 25s ease-in-out infinite;"></div>
      <div class="w-[350px] h-[200px] bg-signal-amber/[0.08] rounded-full blur-[90px] absolute bottom-1/4 right-1/4" style="animation: mesh-drift-2 22s ease-in-out infinite;"></div>
    </div>

    <Container class="relative">
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <div class="col-span-3">
          <ScrollReveal>
            <Badge variant="accent">OUR PROCESS</Badge>
            <h1 class="text-display-lg lg:text-display-xl font-display mt-4 mb-2 wwd-heading-gradient">
              Structured. Transparent. Modular.
            </h1>
            <div class="h-px w-32 bg-gradient-to-r from-[#64C8FF] via-[#A064FF] via-[#50DCB4] to-[#FFB43C] mt-4 mb-6"></div>
            <p class="text-body-lg text-content-secondary max-w-2xl mb-8">
              <span class="text-accent-bright">Four phases.</span> Clear gates. No chaos.
            </p>
          </ScrollReveal>

          <ScrollReveal delay={100}>
            <PhaseRail phases={phaseRailItems} colors={phaseColors} class="mb-12" />
          </ScrollReveal>

          <ScrollReveal delay={200}>
            <p class="text-body-md text-content-muted max-w-2xl">
              Each phase can be commissioned independently. Engage at the stage you need.
            </p>
          </ScrollReveal>
        </div>

        <div class="col-span-2 hidden lg:block">
          <ScrollReveal delay={150}>
            <div class="relative rounded-2xl overflow-hidden shadow-xl hww-hero-vignette">
              <img src="/images/how-we-work/hero-dark.png" alt="Team collaborating on a process flow diagram" class="w-full h-auto hww-hero-dark" loading="eager" />
              <img src="/images/how-we-work/hero-light.png" alt="Team collaborating on a process flow diagram" class="w-full h-auto hww-hero-light" loading="eager" />
            </div>
          </ScrollReveal>
        </div>
      </div>
    </Container>
  </Section>

  {/* ── Section 2: Lifecycle Phases ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section background="elevated" class="relative overflow-hidden">
    <Container>
      <ScrollReveal>
        <SectionHeading
          badge="ENGAGEMENT LIFECYCLE"
          heading="Four Phases. Clear Outcomes."
          headingClass="wwd-heading-gradient"
          description="Each phase is self-contained with defined deliverables. Commission one, or all four."
        />
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10 mt-12">
        {processSteps.map((step, i) => (
          <ScrollReveal delay={i * 100}>
            <div>
              <PhaseCard
                number={step.number}
                title={step.title}
                description={step.description}
                details={step.details}
                icon={step.icon}
                accentColor={step.accentColor}
                image={step.image}
                class="h-full"
              />
            </div>
          </ScrollReveal>
        ))}
      </div>
    </Container>
  </Section>

  {/* ── Section 3: Modular Framework ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section>
    <Container>
      <ScrollReveal>
        <div class="text-center max-w-3xl mx-auto mb-12">
          <Badge variant="accent">MODULAR FRAMEWORK</Badge>
          <h2 class="text-display-md lg:text-display-lg mt-4 mb-4 wwd-heading-gradient">Start Where You Are</h2>
          <p class="text-body-lg text-content-secondary">
            You don't need to begin at Phase 1. Our modular framework lets you engage at the stage that matches your situation.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <div class="hidden md:block">
          <div class="glass-card p-8 lg:p-12 relative dot-grid-bg">
            <svg viewBox="0 0 800 200" class="w-full max-w-4xl mx-auto" aria-label="Modular engagement diagram showing four phases with multiple entry points">
              <rect x="20" y="70" width="160" height="60" rx="8" fill="rgba(100,200,255,0.08)" stroke="rgb(var(--color-glow-steel))" stroke-width="1" opacity="0.5" />
              <text x="100" y="105" text-anchor="middle" fill="rgb(var(--color-content))" font-size="14" font-weight="600">Diagnose</text>

              <rect x="220" y="70" width="160" height="60" rx="8" fill="rgba(160,100,255,0.08)" stroke="rgb(var(--color-glow-steel))" stroke-width="1" opacity="0.5" />
              <text x="300" y="105" text-anchor="middle" fill="rgb(var(--color-content))" font-size="14" font-weight="600">Architect</text>

              <rect x="420" y="70" width="160" height="60" rx="8" fill="rgba(80,220,180,0.08)" stroke="rgb(var(--color-glow-steel))" stroke-width="1" opacity="0.5" />
              <text x="500" y="105" text-anchor="middle" fill="rgb(var(--color-content))" font-size="14" font-weight="600">Build</text>

              <rect x="620" y="70" width="160" height="60" rx="8" fill="rgba(255,180,60,0.08)" stroke="rgb(var(--color-glow-steel))" stroke-width="1" opacity="0.5" />
              <text x="700" y="105" text-anchor="middle" fill="rgb(var(--color-content))" font-size="14" font-weight="600">Optimise</text>

              <line x1="180" y1="100" x2="220" y2="100" stroke="rgb(var(--color-glow-steel))" stroke-width="1" opacity="0.2" />
              <line x1="380" y1="100" x2="420" y2="100" stroke="rgb(var(--color-glow-steel))" stroke-width="1" opacity="0.2" />
              <line x1="580" y1="100" x2="620" y2="100" stroke="rgb(var(--color-glow-steel))" stroke-width="1" opacity="0.2" />

              <g class="arrow-animated">
                <line x1="100" y1="30" x2="100" y2="65" stroke="#64C8FF" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowBlue)" />
                <text x="100" y="20" text-anchor="middle" fill="rgb(var(--color-content-muted))" font-size="11">Start from scratch</text>
              </g>

              <g class="arrow-animated">
                <line x1="300" y1="30" x2="300" y2="65" stroke="#A064FF" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowPurple)" />
                <text x="300" y="20" text-anchor="middle" fill="rgb(var(--color-content-muted))" font-size="11">Have a diagnosis</text>
              </g>

              <g class="arrow-animated">
                <line x1="500" y1="30" x2="500" y2="65" stroke="#50DCB4" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowGreen)" />
                <text x="500" y="20" text-anchor="middle" fill="rgb(var(--color-content-muted))" font-size="11">Need build support</text>
              </g>

              <g class="arrow-animated">
                <line x1="700" y1="30" x2="700" y2="65" stroke="#FFB43C" stroke-width="1.5" opacity="0.7" marker-end="url(#arrowAmber)" />
                <text x="700" y="20" text-anchor="middle" fill="rgb(var(--color-content-muted))" font-size="11">Optimise existing</text>
              </g>

              <defs>
                <marker id="arrowBlue" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
                  <path d="M0,0 L8,4 L0,8" fill="none" stroke="#64C8FF" stroke-width="1.5" />
                </marker>
                <marker id="arrowPurple" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
                  <path d="M0,0 L8,4 L0,8" fill="none" stroke="#A064FF" stroke-width="1.5" />
                </marker>
                <marker id="arrowGreen" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
                  <path d="M0,0 L8,4 L0,8" fill="none" stroke="#50DCB4" stroke-width="1.5" />
                </marker>
                <marker id="arrowAmber" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
                  <path d="M0,0 L8,4 L0,8" fill="none" stroke="#FFB43C" stroke-width="1.5" />
                </marker>
              </defs>
            </svg>

            <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-[400px] h-[60px] bg-signal-blue/10 rounded-full blur-[60px] pointer-events-none" aria-hidden="true"></div>
          </div>
        </div>

        <div class="block md:hidden space-y-4">
          {[
            { label: 'Start from scratch', phase: 'Diagnose', color: '#64C8FF' },
            { label: 'Have a diagnosis', phase: 'Architect', color: '#A064FF' },
            { label: 'Need build support', phase: 'Build', color: '#50DCB4' },
            { label: 'Optimise existing', phase: 'Optimise', color: '#FFB43C' },
          ].map((item) => (
            <div class="flex items-center gap-4">
              <div class="w-2 h-2 rounded-full shrink-0" style={`background: ${item.color};`}></div>
              <div>
                <span class="text-label-md text-content-muted block">{item.label}</span>
                <span class="text-body-md font-semibold text-content">{item.phase}</span>
              </div>
            </div>
          ))}
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <p class="text-body-md text-content-secondary text-center max-w-2xl mx-auto mt-10">
          Whether you need end-to-end delivery or a single diagnostic sprint, our modular framework adapts to where you are.
        </p>
      </ScrollReveal>
    </Container>
  </Section>

  {/* ── Section 4: How We Partner ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section background="elevated">
    <Container>
      <ScrollReveal>
        <SectionHeading
          align="center"
          badge="PARTNERSHIP"
          heading="How We Partner"
          description="Successful engagements require partnership. Here is what each side brings."
        />
      </ScrollReveal>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 mt-12">
        <ScrollReveal direction="left" delay={100}>
          <GlassCard hover padding="lg" class="h-full bg-gradient-to-br from-signal-blue/5 to-transparent">
            <h3 class="text-heading-sm font-semibold mb-5">Your Inputs</h3>
            <FeatureList items={partnershipInputs.client} />
          </GlassCard>
        </ScrollReveal>

        <ScrollReveal direction="right" delay={150}>
          <GlassCard hover padding="lg" class="h-full bg-gradient-to-br from-signal-purple/5 to-transparent">
            <h3 class="text-heading-sm font-semibold mb-5">Our Commitment</h3>
            <FeatureList items={partnershipInputs.ours} />
          </GlassCard>
        </ScrollReveal>
      </div>
    </Container>
  </Section>

  {/* ── Section 5: Milestone Gates ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section>
    <Container>
      <ScrollReveal>
        <SectionHeading
          badge="QUALITY GATES"
          heading="Milestone Gates"
          headingClass="wwd-heading-gradient"
          description="Formal checkpoints between phases. Nothing proceeds without stakeholder approval."
        />
      </ScrollReveal>
      <ScrollReveal delay={100}>
        <div class="mt-12">
          <MilestoneGates gates={milestoneGates} phases={phaseNames} gateColors={['#64C8FF', '#A064FF', '#50DCB4']} />
        </div>
      </ScrollReveal>
    </Container>
  </Section>

  {/* ── Section 6: Commercial Checkpoints ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section background="elevated" class="relative overflow-hidden">
    <Container class="relative">
      <div class="absolute left-0 top-1/3 w-[350px] h-[250px] bg-signal-purple/10 rounded-full blur-[100px] pointer-events-none" style="animation: drift 22s ease-in-out infinite;" aria-hidden="true"></div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <div>
          <ScrollReveal>
            <SectionHeading
              badge="COMMERCIAL MODEL"
              heading="Transparent Commercial Checkpoints"
              description="No surprises. Payment milestones are tied to visible deliverables and stakeholder sign-off."
            />
          </ScrollReveal>
        </div>

        <ScrollReveal delay={100}>
          <GlassCard padding="lg" class="shimmer-border">
            <div class="space-y-5">
              {commercialCheckpoints.map((cp, i) => (
                <ScrollReveal delay={i * 100 + 150}>
                  <div class="flex items-start gap-4">
                    <div
                      class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-body-xs shrink-0"
                      style={`background: linear-gradient(135deg, ${checkpointColors[i]}33, ${checkpointColors[i]}1a); color: ${checkpointColors[i]}; animation: glow-breathe 8s ease-in-out infinite; animation-delay: ${i * 0.5}s;`}
                    >
                      {cp.number}
                    </div>
                    <div>
                      <h3 class="text-body-md font-semibold mb-0.5">{cp.title}</h3>
                      <p class="text-body-sm text-content-secondary">{cp.description}</p>
                    </div>
                  </div>
                </ScrollReveal>
              ))}
            </div>
          </GlassCard>
        </ScrollReveal>
      </div>
    </Container>
  </Section>

  {/* ── Section 7: Definition of Done ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section class="relative overflow-hidden">
    <Container class="relative">
      <div class="absolute right-0 top-1/4 w-[300px] h-[200px] bg-signal-emerald/10 rounded-full blur-[100px] pointer-events-none" style="animation: drift 18s ease-in-out infinite;" aria-hidden="true"></div>

      <ScrollReveal>
        <SectionHeading
          align="center"
          badge="DEFINITION OF DONE"
          heading="What Done Looks Like"
          headingClass="wwd-heading-gradient"
          description="Every engagement has a defined endpoint. Here is what completion means."
        />
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
        {definitionOfDone.map((item, i) => (
          <ScrollReveal delay={i * 150}>
            <GlassCard
              hover
              padding="md"
              class="text-center h-full hover:scale-[1.02] transition-transform duration-300 border-t-2"
              style={`border-top-color: ${dodColors[i]};`}
            >
              <div
                class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center"
                style={`background: linear-gradient(135deg, ${dodColors[i]}33, ${dodColors[i]}1a); color: ${dodColors[i]};`}
              >
                <Icon name={dodIcons[i]} size={20} />
              </div>
              <h3 class="text-heading-xs font-semibold mb-2">{item.title}</h3>
              <p class="text-body-sm text-content-secondary">{item.description}</p>
            </GlassCard>
          </ScrollReveal>
        ))}
      </div>
    </Container>
  </Section>

  {/* ── Section 8: Bottom CTA ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section padding="none" class="py-40 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[793px] h-[499px] rounded-full blur-[150px] bg-glow-steel/10"></div>
    </div>

    <Container class="relative">
      <ScrollReveal>
        <div class="text-center">
          <SectionHeading
            align="center"
            badge="GET STARTED"
            heading="Ready to Discuss Scope?"
            headingClass="wwd-heading-gradient"
            description="Book a 30-minute scoping call. We'll map your situation to our process and tell you exactly where to start."
          />
          <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <Button variant="primary" size="lg" href="/contact">Book a Scoping Discussion</Button>
            <Button variant="outline" size="lg" href="/how-we-price">View Pricing</Button>
          </div>

          <div class="flex flex-wrap justify-center gap-3 mt-8">
            {['Structured Delivery', 'No Surprises', 'Clear Milestones', 'Modular Engagement'].map((badge) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-label-md rounded-full border border-surface-border/[var(--alpha-surface-border)] text-content-muted bg-surface-elevated/50">
                <svg width="6" height="6" viewBox="0 0 12 12" fill="currentColor" class="opacity-40" aria-hidden="true">
                  <circle cx="6" cy="6" r="3" />
                </svg>
                {badge}
              </span>
            ))}
          </div>
        </div>
      </ScrollReveal>
    </Container>
  </Section>

</PageLayout>
