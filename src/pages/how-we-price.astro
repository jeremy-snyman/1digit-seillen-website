---
import PageLayout from '@layouts/PageLayout.astro';
import Section from '@components/layout/Section.astro';
import Container from '@components/layout/Container.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import ScrollReveal from '@components/interactive/ScrollReveal.astro';
import GlassCard from '@components/ui/GlassCard.astro';
import Icon from '@components/ui/Icon.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import Accordion from '@components/interactive/Accordion.astro';
import AccordionItem from '@components/interactive/AccordionItem.astro';
import PhaseRail from '@components/content/PhaseRail.astro';
import PhaseCard from '@components/content/PhaseCard.astro';
import {
  pricingPrinciples,
  engagementPhases,
  engagementCommitments,
} from '@content/data/pricing';
import {
  processSteps as campaignProcess,
  deliverables as campaignDeliverables,
} from '@content/data/ai-readiness-campaign';
import { pricingFAQ } from '@content/data/faq';

const title = 'How We Price';
const description = 'We price around outcomes and defined scope — not hours, not headcount, not open-ended retainers.';

const phaseRailItems = engagementPhases.map((p) => ({ number: p.number, title: p.title }));
const phaseColors = ['#64C8FF', '#A064FF', '#50DCB4', '#FFB43C'];
const accentColors = ['#64C8FF', '#A064FF', '#50DCB4', '#FFB43C', '#64C8FF'];
---

<PageLayout title={title} description={description}>

  {/* ── S1: Hero ── */}
  <Section class="pt-40 pb-24 relative overflow-hidden min-h-[70vh]">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
      <div class="w-[600px] h-[300px] bg-signal-blue/15 rounded-full blur-[120px]" style="animation: drift 20s ease-in-out infinite;"></div>
      <div class="w-[400px] h-[250px] bg-signal-purple/10 rounded-full blur-[100px] absolute top-1/3 left-1/3" style="animation: mesh-drift-1 25s ease-in-out infinite;"></div>
      <div class="w-[350px] h-[200px] bg-signal-amber/[0.08] rounded-full blur-[90px] absolute bottom-1/4 right-1/4" style="animation: mesh-drift-2 22s ease-in-out infinite;"></div>
    </div>

    <Container class="relative">
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <div class="col-span-3">
          <ScrollReveal>
            <Badge variant="accent">HOW WE PRICE</Badge>
            <h1 class="text-display-lg lg:text-display-xl font-display mt-4 mb-2 wwd-heading-gradient">
              We price around outcomes. Not hours.
            </h1>
            <div class="h-px w-32 bg-gradient-to-r from-[#64C8FF] via-[#A064FF] via-[#50DCB4] to-[#FFB43C] mt-4 mb-6"></div>
            <p class="text-body-lg text-content-secondary max-w-2xl mb-4">
              <span class="text-accent-bright">Defined scope.</span> Clear deliverables. Published investment ranges.
            </p>
            <p class="text-body-md text-content-muted max-w-2xl mb-8">
              Every engagement has a defined scope, clear deliverables, and a published investment range. You know what you are getting before you commit.
            </p>
          </ScrollReveal>

          <ScrollReveal delay={100}>
            <PhaseRail phases={phaseRailItems} colors={phaseColors} class="mb-12" />
          </ScrollReveal>

          <ScrollReveal delay={200}>
            <div class="flex flex-col sm:flex-row gap-4">
              <Button variant="primary" size="lg" href="/contact">Discuss Your Engagement</Button>
              <Button variant="outline" size="lg" href="#assessment-example">See an Example</Button>
            </div>
          </ScrollReveal>
        </div>

        <div class="col-span-2 hidden lg:block">
          <ScrollReveal delay={150}>
            <div class="relative rounded-2xl overflow-hidden shadow-xl hww-hero-vignette">
              <img src="/images/pricing/hero.png" alt="Value creation and outcome-based engagement — revenue increase, market expansion, efficiency" class="w-full h-auto" loading="eager" />
            </div>
          </ScrollReveal>
        </div>
      </div>
    </Container>
  </Section>

  {/* ── S2: Philosophy Pillars ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section background="elevated">
    <Container>
      <ScrollReveal>
        <SectionHeading
          align="center"
          badge="PHILOSOPHY"
          heading="How We Think About Value"
          headingClass="wwd-heading-gradient"
          description="Five principles that guide how we scope, price, and deliver every engagement."
        />
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mt-12">
        {pricingPrinciples.map((item, i) => (
          <ScrollReveal delay={i * 100}>
            <GlassCard
              hover
              padding="md"
              class="h-full border-t-2 hover:scale-[1.02] transition-transform duration-300"
              style={`border-top-color: ${accentColors[i]};`}
            >
              <div class="relative">
                <div class="absolute -top-2 -right-2 text-[80px] font-bold leading-none text-content/[0.03] pointer-events-none select-none">
                  {item.number}
                </div>

                <div class="relative z-10">
                  <div
                    class="w-12 h-12 rounded-xl flex items-center justify-center mb-4"
                    style={`background: linear-gradient(135deg, ${accentColors[i]}33, ${accentColors[i]}1a); color: ${accentColors[i]};`}
                  >
                    <Icon name={item.icon} size={22} />
                  </div>
                  <h3 class="text-heading-xs font-semibold mb-2">{item.title}</h3>
                  <p class="text-body-sm text-content-secondary">{item.description}</p>
                </div>
              </div>
            </GlassCard>
          </ScrollReveal>
        ))}
      </div>
    </Container>
  </Section>

  {/* ── S3: Engagement Journey ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section>
    <Container>
      <ScrollReveal>
        <SectionHeading
          align="center"
          badge="ENGAGEMENT LIFECYCLE"
          heading="Four Phases. One Structured Journey."
          headingClass="wwd-heading-gradient"
          description="Each phase is self-contained with defined deliverables. Commission one, or all four."
        />
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10 mt-12">
        {engagementPhases.map((phase, i) => (
          <ScrollReveal delay={i * 100}>
            <div>
              <PhaseCard
                number={phase.number}
                title={phase.title}
                description={phase.description}
                details={phase.details}
                icon={phase.icon}
                accentColor={phase.accentColor}
                image={phase.image}
                class="h-full"
              />
            </div>
          </ScrollReveal>
        ))}
      </div>
    </Container>
  </Section>

  {/* ── S4: Assessment Spotlight — AI Readiness Assessment ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section id="assessment-example" background="elevated" class="relative overflow-hidden">
    <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-[400px] h-[300px] bg-signal-blue/10 rounded-full blur-[120px] pointer-events-none" style="animation: drift 20s ease-in-out infinite;" aria-hidden="true"></div>

    <Container class="relative">
      <ScrollReveal>
        <SectionHeading
          badge="EXAMPLE ENGAGEMENT"
          heading="AI Readiness Assessment"
          headingClass="wwd-heading-gradient"
          description="Where most enterprise relationships begin — a structured, expert-led engagement that gives your leadership team a clear picture of where you stand."
        />
      </ScrollReveal>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mt-12">
        {/* Process column */}
        <ScrollReveal delay={100}>
          <GlassCard padding="lg" class="h-full">
            <div class="flex flex-wrap items-center gap-4 mb-6">
              <span class="text-accent-bright text-heading-md font-semibold">£8,000</span>
              <span class="text-body-sm text-content-muted">Fixed Price</span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 text-label-md rounded-full border border-signal-blue/30 text-content-muted">
                <svg width="8" height="8" viewBox="0 0 16 16" fill="currentColor" class="opacity-60" aria-hidden="true">
                  <circle cx="8" cy="8" r="4" />
                </svg>
                4 Weeks
              </span>
            </div>

            <h4 class="text-label-sm text-content-muted uppercase tracking-wider mb-4">Process</h4>
            <div class="space-y-5">
              {campaignProcess.map((step) => (
                <div class="flex items-start gap-4">
                  <div
                    class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-body-xs shrink-0"
                    style={`background: linear-gradient(135deg, ${phaseColors[step.step - 1]}33, ${phaseColors[step.step - 1]}1a); color: ${phaseColors[step.step - 1]};`}
                  >
                    {step.step}
                  </div>
                  <div>
                    <div class="flex items-center gap-2 mb-0.5">
                      <h5 class="text-body-md font-semibold">{step.title}</h5>
                      <span class="text-label-sm text-content-muted">{step.duration}</span>
                    </div>
                    <p class="text-body-sm text-content-secondary">{step.description}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8">
              <Button variant="primary" size="md" href="/campaign/ai-readiness-assessment">Learn More</Button>
            </div>
          </GlassCard>
        </ScrollReveal>

        {/* Deliverables column */}
        <ScrollReveal delay={200}>
          <GlassCard padding="lg" class="h-full shimmer-border">
            <h4 class="text-label-sm text-content-muted uppercase tracking-wider mb-4">What You Receive</h4>
            <div class="space-y-5">
              {campaignDeliverables.map((item, i) => (
                <div class="flex items-start gap-4">
                  <div
                    class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-body-xs shrink-0"
                    style={`background: linear-gradient(135deg, ${phaseColors[i % 4]}33, ${phaseColors[i % 4]}1a); color: ${phaseColors[i % 4]};`}
                  >
                    {item.number}
                  </div>
                  <div>
                    <h5 class="text-body-md font-semibold mb-0.5">{item.title}</h5>
                    <p class="text-body-sm text-content-secondary">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </GlassCard>
        </ScrollReveal>
      </div>
    </Container>
  </Section>

  {/* ── S5: Commitments ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section>
    <Container>
      <ScrollReveal>
        <SectionHeading
          align="center"
          badge="EVERY ENGAGEMENT"
          heading="What You Always Get"
          headingClass="wwd-heading-gradient"
          description="Regardless of scope, every engagement includes these commitments."
        />
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
        {engagementCommitments.map((item, i) => (
          <ScrollReveal delay={i * 100}>
            <GlassCard
              hover
              padding="md"
              class="text-center h-full border-t-2 hover:scale-[1.02] transition-transform duration-300"
              style={`border-top-color: ${accentColors[i]};`}
            >
              <div
                class="w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center"
                style={`background: linear-gradient(135deg, ${accentColors[i]}33, ${accentColors[i]}1a); color: ${accentColors[i]};`}
              >
                <Icon name={item.icon} size={20} />
              </div>
              <h3 class="text-heading-xs font-semibold mb-2">{item.title}</h3>
              <p class="text-body-sm text-content-secondary">{item.description}</p>
            </GlassCard>
          </ScrollReveal>
        ))}
      </div>
    </Container>
  </Section>

  {/* ── S6: FAQ ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section background="elevated">
    <Container size="narrow">
      <ScrollReveal>
        <SectionHeading
          align="center"
          badge="FAQ"
          heading="Common Questions"
          headingClass="wwd-heading-gradient"
          description="Answers to the questions our clients ask most."
        />
      </ScrollReveal>
      <div class="mt-12">
        <ScrollReveal>
          <Accordion>
            {pricingFAQ.map((item) => (
              <AccordionItem question={item.question} answer={item.answer} />
            ))}
          </Accordion>
        </ScrollReveal>
      </div>
    </Container>
  </Section>

  {/* ── S7: Bottom CTA ── */}
  <div class="wwd-section-divider" aria-hidden="true"></div>
  <Section padding="none" class="py-40 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[793px] h-[499px] rounded-full blur-[150px] bg-glow-steel/10"></div>
    </div>

    <Container class="relative">
      <ScrollReveal>
        <div class="text-center">
          <SectionHeading
            align="center"
            badge="GET STARTED"
            heading="Ready to Scope Your Engagement?"
            headingClass="wwd-heading-gradient"
            description="Book a 30-minute pricing and scope discussion. No obligation, no hard sell — just clarity on what the right engagement looks like for you."
          />
          <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <Button variant="primary" size="lg" href="/contact">Book a Scope Discussion</Button>
            <Button variant="outline" size="lg" href="/campaign/ai-readiness-assessment">AI Readiness Assessment</Button>
          </div>

          <div class="flex flex-wrap justify-center gap-3 mt-8">
            {['Defined Scope', 'Fixed Pricing', 'Clear Deliverables', 'No Surprises'].map((badge) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-label-md rounded-full border border-surface-border/[var(--alpha-surface-border)] text-content-muted bg-surface-elevated/50">
                <svg width="6" height="6" viewBox="0 0 12 12" fill="currentColor" class="opacity-40" aria-hidden="true">
                  <circle cx="6" cy="6" r="3" />
                </svg>
                {badge}
              </span>
            ))}
          </div>
        </div>
      </ScrollReveal>
    </Container>
  </Section>

</PageLayout>
